# Environment Configuration
# Copy this file to .env and adjust values as needed.

# Application
APP_NAME=OCR Benchmark Platform
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Server
HOST=0.0.0.0
PORT=8000

# Redis
REDIS_URL=redis://redis:6379/0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ocr_platform

# Mistral OCR (placeholder for future milestones)
MISTRAL_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:3000
